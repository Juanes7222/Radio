# ── Infisical (optional) ───────────────────────────────────────
# Fill these in to load secrets from Infisical at runtime.
# Leave them empty or commented to use only local .env values.
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
# INFISICAL_SITE_URL=https://app.infisical.com
# INFISICAL_SECRET_PATH=/

# ── Server ─────────────────────────────────────────────────────
PORT=3000

# ── AzuraCast ───────────────────────────────────────────────────
AZURACAST_URL=http://localhost:8080
AZURACAST_STATION_ID=la_voz_de_la_verdad
AZURACAST_PLAYLIST_ID=12
AZURACAST_NEWS_PLAYLIST_ID=12

# ── Public / Frontend URLs ─────────────────────────────────────
PUBLIC_URL=https://www.lavozverdad.com
FRONTEND_URL=https://www.lavozverdad.com,http://192.168.1.4:5173

# ── Google OAuth ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ── Admin Whitelist ────────────────────────────────────────────
ADMIN_WHITELIST=admin1@example.com,admin2@example.com

# ── Workers ────────────────────────────────────────────────────
WS_PORT=3001
JOB_DISPATCH_INTERVAL_MS=2000
WORKER_HEARTBEAT_TIMEOUT_MS=60000

# ── YouTube ────────────────────────────────────────────────────
YOUTUBE_CHANNEL_IDS=UCVqtYvLNHvGymJFoGeRH7nw
MAX_VIDEO_DURATION_SECONDS=600
MAX_RETRY_ATTEMPTS=3

# ── Locutor ────────────────────────────────────────────────────
KOKORO_URL=http://localhost:8880
MEDIA_DIR=/var/azuracast/stations/1/media/locutores
TIMEZONE=America/Bogota
STATION_NAME="La Voz de la Verdad"

# ── Email ──────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_PROVIDER=smtp
# EMAIL_FROM=no-reply@lavozverdad.com
# EMAIL_FROM_NAME="La Voz de la Verdad"
# BREVO_API_KEY=
# PRAYER_EMAIL_RECIPIENTS=admin1@example.com,admin2@example.com

# ── Secrets (fallback for local development only) ───────────────
# These should ideally live in Infisical. They are kept here as
# a fallback when INFISICAL_CLIENT_ID is not configured.
# NEVER commit real values to version control.
# AZURACAST_API_KEY=
# JWT_SECRET=
# PANEL_SECRET=
# WORKER_AUTH_SECRET=
# WEBHOOK_SECRET=
# FB_VERIFY_TOKEN=
# FB_APP_SECRET=
