# ── Puerto del servidor ────────────────────────────────────────
PORT=3001

# ── AzuraCast ─────────────────────────────────────────────────
# URL base de la instancia de AzuraCast (sin barra al final)
# Si te quieres conectar al servidor remoto de pruebas/producción pon la URL real (p.e: https://demo.azuracast.com)
AZURACAST_URL=https://demo.azuracast.com
# API Key generada en AzuraCast → Mi Cuenta → API Keys
AZURACAST_API_KEY=tu_api_key_aqui
# Shortcode o ID numérico de la estación
AZURACAST_STATION_ID=la_voz_de_la_verdad
# ID de la playlist para videos de YouTube (noticias)
AZURACAST_PLAYLIST_ID=1
# ID de la playlist de noticias que se limpia automáticamente
AZURACAST_NEWS_PLAYLIST_ID=2

# ── Google OAuth ───────────────────────────────────────────────
# Client ID del proyecto en Google Cloud Console
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com

# ── Sesiones ──────────────────────────────────────────────────
# Cadena aleatoria y secreta para firmar los JWT de sesión
# Genera una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# ── URL pública del sitio ──────────────────────────────────────
# Se usa para reescribir las URLs internas que devuelve AzuraCast
# (AzuraCast a veces retorna http://localhost/... en los campos de URL)
PUBLIC_URL=https://www.lavozverdad.com

# ── Lista blanca de administradores ──────────────────────────
# Correos de Google separados por comas (sin espacios)
ADMIN_WHITELIST=tumail@gmail.com,otromail@gmail.com

# Facebook Webhook
FB_VERIFY_TOKEN=token_que_tu_eliges
FB_APP_SECRET=app_secret_de_meta

PANEL_SECRET=un_secreto_largo_y_aleatorio_para_el_panel_de_control

# ── Workers ────────────────────────────────────────────────────
# Secreto compartido para autenticación de workers WebSocket
# Genera una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
WORKER_AUTH_SECRET=un_secreto_largo_y_aleatorio_para_workers
# Puerto del servidor WebSocket (default: 3001)
WS_PORT=3001
# Intervalo de dispatch de jobs en ms (default: 2000)
JOB_DISPATCH_INTERVAL_MS=2000
# Timeout de heartbeat de workers en ms (default: 60000)
WORKER_HEARTBEAT_TIMEOUT_MS=60000

# ── YouTube ────────────────────────────────────────────────────
# IDs de canales de YouTube separados por comas
YOUTUBE_CHANNEL_IDS=UCxxxx,UCyyyy
# Duración máxima de videos en segundos (default: 600)
MAX_VIDEO_DURATION_SECONDS=600
# Intentos máximos de reintento (default: 3)
MAX_RETRY_ATTEMPTS=3

WEBHOOK_SECRET=un_secreto_largo_y_aleatorio_para_verificar_webhooks