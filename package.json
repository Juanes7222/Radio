{
  "name": "radio-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@radio/web",
    "dev:mobile": "turbo dev --filter=@radio/mobile",
    "dev:backend": "turbo dev --filter=radio-admin-backend"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "expo": "~53.0.0",
    "expo-router": "~5.1.11",
    "react-native": "0.79.6",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6"
  }
}
